# Supabase public credentials — safe to ship in client bundle.
#
# Local dev: copy this file to `.env.local` and fill with values from
#   https://supabase.com/dashboard → Project Settings → API
#
# Production (Vercel): set in Project Settings → Environment Variables
# with the same names, and check BOTH "Production" and "Preview"
# so pull-request previews can hit the same Supabase project.
#
# The service_role key is NEVER needed here — the app only uses the
# anon (publishable) key. If you accidentally set the service_role key,
# it will be exposed in the browser bundle. Do not do this.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
